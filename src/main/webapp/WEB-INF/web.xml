<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <display-name>学生信息管理系统</display-name>

    <welcome-file-list>
        <welcome-file>jsp/studentlist.jsp</welcome-file>
    </welcome-file-list>

    <!-- ListStudentServlet -->
    <servlet>
        <servlet-name>ListStudentServlet</servlet-name>
        <servlet-class>com.studentmanager.control.ListStudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ListStudentServlet</servlet-name>
        <url-pattern>/ListStudentServlet.do</url-pattern>
    </servlet-mapping>

    <!-- InsertStudentServlet -->
    <servlet>
        <servlet-name>InsertStudentServlet</servlet-name>
        <servlet-class>com.studentmanager.control.InsertStudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>InsertStudentServlet</servlet-name>
        <url-pattern>/InsertStudentServlet.do</url-pattern>
    </servlet-mapping>

    <!-- UpStudentServlet (修改前) -->
    <servlet>
        <servlet-name>UpStudentServlet</servlet-name>
        <servlet-class>com.studentmanager.control.UpStudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpStudentServlet</servlet-name>
        <url-pattern>/UpStudentServlet.do</url-pattern>
    </servlet-mapping>

    <!-- DoStudentServlet (修改后) -->
    <servlet>
        <servlet-name>DoStudentServlet</servlet-name>
        <servlet-class>com.studentmanager.control.DoStudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DoStudentServlet</servlet-name>
        <url-pattern>/DoStudentServlet.do</url-pattern>
    </servlet-mapping>

    <!-- ShowStudentServlet (删除前) -->
    <servlet>
        <servlet-name>ShowStudentServlet</servlet-name>
        <servlet-class>com.studentmanager.control.ShowStudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ShowStudentServlet</servlet-name>
        <url-pattern>/ShowStudentServlet.do</url-pattern>
    </servlet-mapping>

    <!-- DeleteStudentServlet (删除后) -->
    <servlet>
        <servlet-name>DeleteStudentServlet</servlet-name>
        <servlet-class>com.studentmanager.control.DeleteStudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteStudentServlet</servlet-name>
        <url-pattern>/DeleteStudentServlet.do</url-pattern>
    </servlet-mapping>

    <!-- ImportStudentServlet (Excel批量导入) -->
    <servlet>
        <servlet-name>ImportStudentServlet</servlet-name>
        <servlet-class>com.studentmanager.control.ImportStudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ImportStudentServlet</servlet-name>
        <url-pattern>/ImportStudentServlet.do</url-pattern>
    </servlet-mapping>

</web-app>
